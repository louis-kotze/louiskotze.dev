  name: 'Louis Kotze',
  alternateName: 'loukot',
  url: 'https://louiskotze.dev/',
  mainEntityOfPage: 'https://louiskotze.dev/about/',
  jobTitle: 'Senior Full-Stack Engineer',
  description:
    'Senior full-stack engineer and Linux kernel contributor based in Stilbay, South Africa. Currently leading a team at iOCO Digital delivering data-visualization platform features for Takeda, while also shipping patches upstream to the Linux kernel and wireless regulatory database.',
  email: 'mailto:louis@louiskotze.dev',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Stilbay',
    addressRegion: 'Western Cape',
    addressCountry: 'ZA',
  },
  worksFor: {
    '@type': 'Organization',
    name: 'iOCO Digital',
    url: 'https://iocodigital.com/',
  },
  alumniOf: [
    { '@type': 'Organization', name: 'BMW IT Hub South Africa' },
    { '@type': 'Organization', name: 'Discovery Limited' },
    { '@type': 'Organization', name: 'Hello Group' },
    { '@type': 'CollegeOrUniversity', name: 'Varsity College' },
  ],
  knowsAbout: [
    'Linux kernel development',
    'wireless networking',
    'Angular',
    'TypeScript',
    'Java',
    'Kafka',
    'Kubernetes',
    'distributed systems',
    'engineering leadership',
    'Agile delivery',
    'mentorship',
  ],
  sameAs: [
    'https://github.com/louis-kotze',
