---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base
  title="Writing — Louis Kotze"
  description="Notes on Linux kernel contributions, engineering practice, and the software job landscape."
>
  <h1>Writing</h1>
  <p class="muted">
    Long-form notes on kernel contributions, engineering practice, and the
    current software job landscape.
  </p>

  {posts.length === 0 ? (
    <p class="muted">
      First post is in the kitchen. Check back after the Linux kernel merge
      window closes.
    </p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}><strong>{post.data.title}</strong></a>
          <div class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-ZA', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {post.data.tags.length > 0 && (
              <span> &middot; {post.data.tags.join(', ')}</span>
            )}
          </div>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</Base>
